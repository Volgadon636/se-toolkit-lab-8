{
  "providers": {
    "custom": {
      "apiKey": "REPLACE_VIA_ENV_IN_DOCKER",
      "apiBase": "http://localhost:42005/v1"
    }
  },
  "agents": {
    "defaults": {
      "model": "coder-model",
      "provider": "custom",
      "workspace": "./workspace"
    }
  },
  "channels": {
    "webchat": {
      "enabled": true,
      "host": "127.0.0.1",
      "port": 8765,
      "allow_from": ["*"]
    }
  },
  "tools": {
    "mcpServers": {
      "lms": {
        "command": "python",
        "args": ["-m", "mcp_lms"],
        "env": {
          "NANOBOT_LMS_BACKEND_URL": "http://localhost:42002",
          "NANOBOT_LMS_API_KEY": "REPLACE_WITH_LMS_KEY",
          "VICTORIALOGS_BASE_URL": "http://localhost:42010",
          "VICTORIATRACES_BASE_URL": "http://localhost:42011"
        }
      }
    }
  }
}
